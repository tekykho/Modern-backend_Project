<%- contentFor('title') %>
    Shipment Information

    <%- contentFor('body') %>
        <h1>Update Shipment Information</h1>
        <form method="POST">
            <input type="hidden" name="old_route_id" value="<%= currentShipment.route_id %>" />
            <div>
                <label class="mt-2 fw-bold">Client Company Name</label>
                <input type="text" class="form-control" name="company_name" value="<%= client.company_name %>"
                    readonly />
            </div>
            <div>
                <label class="mt-2 fw-bold">Client First Name</label>
                <input type="text" class="form-control" name="first_name" value="<%= client.first_name %>" readonly />
            </div>
            <div>
                <label class="mt-2 fw-bold">Client Last Name</label>
                <input type="text" class="form-control" name="last_name" value="<%= client.last_name %>" readonly />
            </div>
            <div>
                <label class="mt-2 fw-bold">Contact Email</label>
                <input type="text" class="form-control" name="contact_email" value="<%= client.contact_email %>"
                    readonly />
            </div>
            <div>
                <label class="mt-2 fw-bold">Origin Hub</label>
                <input type="text" class="form-control" name="origin_hub" value="<%= currentShipment.origin_hub %>" />
            </div>
            <div>
                <label class="mt-2 fw-bold">Destination Hub</label>
                <input type="text" class="form-control" name="destination_hub"
                    value="<%= currentShipment.destination_hub || '' %>" />
            </div>
            <!-- <div>
                <label class="mt-2 fw-bold">Shipping Date</label>
                <input type="text" class="form-control" name="shipping_date" placeholder="YYYY-MM-DD HH:mm:ss"
                    value="<%= currentShipment.shipping_date ? currentShipment.shipping_date.toISOString().slice(0, 19).replace('T', ' ') : '' %>"
                    required />
            </div> -->
            <div>
                <label class="mt-2 fw-bold">Shipping Date</label>
                <input type="datetime-local" class="form-control" name="shipping_date"
                    value="<%= currentShipment.shipping_date ? currentShipment.shipping_date.toISOString().slice(0, 16) : '' %>"
                    required />
            </div>
            <div>
                <label class="mt-2 fw-bold">Shipment Day</label>
                <input type="text" class="form-control" name="shipment_day"
                    value="<%= currentShipment.shipment_day || '' %>" />
            </div>
            <div>
                <button class="btn btn-primary mt-3">Submit</button>
                <button class="btn btn-success mt-3">Cancel</button>
            </div>
        </form>