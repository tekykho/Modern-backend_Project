<%- contentFor('title') %>
    Shipment Information

    <%- contentFor('body') %>
        <h1>Update Shipment Information</h1>
        <form method="POST">
            <div>
                <label class="mt-2 fw-bold">Client Company Name</label>
                <input type="text" class="form-control" name="company_name" value="<%= shipment.company_name %>" readonly/>
            </div>
            <div>
                <label class="mt-2 fw-bold">Client First Name</label>
                <input type="text" class="form-control" name="first_name" value="<%= shipment.first_name %>" readonly />
            </div>
            <div>
                <label class="mt-2 fw-bold">Client Last Name</label>
                <input type="text" class="form-control" name="first_name" value="<%= shipment.last_name %>" readonly />
            </div>
            <div>
                <label class="mt-2 fw-bold">Contact Email</label>
                <input type="text" class="form-control" name="contact_email" value="<%= shipment.contact_email %>" readonly/>
            </div>
            <div>
                <label class="mt-2 fw-bold">Origin Hub</label>
                <input type="text" class="form-control" name="origin_hub" value="<%= shipment.origin_hub %>" />
            </div>
            <div>
                <label class="mt-2 fw-bold">Destination Hub</label>
                <input type="text" class="form-control" name="destination_hub"
                    value="<%= shipment.destination_hub %>" />
            </div>
            <div>
                <label class="mt-2 fw-bold">Shipping Date</label>
                <input type="date" class="form-control" name="shipping_date"
                    value="<%= shipment.shipping_date ? shipment.shipping_date.toISOString().split('T')[0] : '' %>" />
            </div>
            <div>
                <label class="mt-2 fw-bold">Shipment Day</label>
                <input type="text" class="form-control" name="shipment_day" value="<%= shipment.shipment_day %>" />
            </div>
            <div>
                <button class="btn btn-primary mt-3">Submit</button>
                <button class="btn btn-success mt-3">Cancel</button>
            </div>
        </form>